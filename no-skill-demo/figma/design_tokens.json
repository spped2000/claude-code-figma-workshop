{
  "colors": {
    "primary": "#E67E22",
    "primary-dark": "#D35400",
    "sidebar-bg": "#1C2833",
    "sidebar-text": "#ECF0F1",
    "sidebar-hover": "#2C3E50",
    "content-bg": "#F8F9FA",
    "card-bg": "#FFFFFF",
    "border": "#E5E7E9",
    "success": "#27AE60",
    "warning": "#F39C12",
    "danger": "#E74C3C",
    "info": "#3498DB",
    "text-primary": "#2C3E50",
    "text-secondary": "#566573",
    "text-muted": "#7F8C8D"
  },
  "typography": {
    "font-family": "'Sarabun', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif",
    "h1": { "size": "28px", "weight": 700, "line-height": "36px" },
    "h2": { "size": "22px", "weight": 600, "line-height": "30px" },
    "h3": { "size": "18px", "weight": 600, "line-height": "26px" },
    "body": { "size": "14px", "weight": 400, "line-height": "22px" },
    "small": { "size": "12px", "weight": 400, "line-height": "18px" },
    "kpi-number": { "size": "36px", "weight": 700, "line-height": "44px" }
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "2xl": 48
  },
  "radius": {
    "sm": 4,
    "md": 8,
    "lg": 12,
    "full": 9999
  },
  "shadow": {
    "sm": "0 1px 2px rgba(0, 0, 0, 0.05)",
    "md": "0 4px 6px rgba(0, 0, 0, 0.07)",
    "lg": "0 10px 15px rgba(0, 0, 0, 0.1)"
  },
  "layout": {
    "sidebar-width": 240,
    "header-height": 64,
    "container-max-width": 1440,
    "breakpoint-mobile": 768
  }
}
